local CurrentThemeName = SavedConfig.__theme or "white"
local C = {}
for k,v in pairs(Themes[CurrentThemeName] or Themes.white) do C[k]=v end

-- ThemeListeners: functions called when theme changes to recolor live UI
local ThemeListeners = {}
local function onThemeChange(fn) ThemeListeners[#ThemeListeners+1]=fn end

-- Fine-grained recolor registry: each entry is { obj, prop, colorKey, extraProps }
-- e.g. { obj=frame, prop="BackgroundColor3", colorKey="Row" }
-- extraProps: optional table of { prop, value } tweened alongside (e.g. transparency)
local RecolorRegistry = {}
local function regColor(obj, prop, colorKey, transparency)
    if not obj or not prop or not colorKey then return end
    RecolorRegistry[#RecolorRegistry+1] = { obj=obj, prop=prop, key=colorKey, alpha=transparency }
end

local function applyTheme(name)
    local t=Themes[name]
    if not t then return end
    CurrentThemeName=name
    for k,v in pairs(t) do C[k]=v end
    SavedConfig.__theme=name
    if AutoSaveEnabled then doSaveAll() end
    -- Walk the registry and tween every registered element
    for _,entry in ipairs(RecolorRegistry) do
        local obj = entry.obj
        if obj and obj.Parent then  -- skip destroyed objects
            local props = { [entry.prop] = C[entry.key] }
            if entry.alpha ~= nil then
                -- alpha is either a fixed number or a C key string
                props.BackgroundTransparency = type(entry.alpha)=="string" and (C[entry.alpha] or 0) or entry.alpha
            end
            pcall(tw, obj, props, 0.25)
        end
    end
    for _,fn in ipairs(ThemeListeners) do pcall(fn,C) end
end

