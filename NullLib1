-- REGISTER SAVEABLE  (fixes "attempt to call a nil value" error)
-- ─────────────────────────────────────────────
local function registerSaveable(flag, ctype, obj)
    if not flag then return end
    SaveRegistry[flag] = { ctype = ctype, obj = obj }
end

