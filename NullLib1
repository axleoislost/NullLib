-- SAVE / LOAD
-- ─────────────────────────────────────────────
local SAVE_FILE = "NullLib_config.json"

-- Check if file I/O APIs exist at all (varies by executor)
local HAS_IO = type(readfile) == "function" and type(writefile) == "function"

local function safeRead(path)
    if not HAS_IO then return nil end
    -- isfile check: some executors throw on readfile of missing file instead of returning nil
    if type(isfile) == "function" then
        local ok, exists = pcall(isfile, path)
        if not ok or not exists then return nil end
    end
    local ok, data = pcall(readfile, path)
    if not ok or type(data) ~= "string" or data == "" then return nil end
    return data
end

local function safeWrite(path, data)
    if not HAS_IO then return false end
    -- Some executors need the folder to exist first
    if type(makefolder) == "function" then
        -- Only create folder if path contains a directory component
        local folder = path:match("^(.+)/[^/]+$")
        if folder then pcall(makefolder, folder) end
    end
    local ok, err = pcall(writefile, path, data)
    return ok
end

-- Minimal JSON encode/decode (no deps)
local function jsonEncode(t)
    local function enc(v)
        local tv=type(v)
        if tv=="boolean" then return v and "true" or "false"
        elseif tv=="number" then return tostring(v)
        elseif tv=="string" then return '"'..v:gsub('\\','\\\\'):gsub('"','\\"')..'"'
        elseif tv=="table" then
            local isArr=true; local n=0
            for k in pairs(v) do n=n+1; if type(k)~="number" then isArr=false; break end end
            if isArr and n==#v then
                local p={}; for _,val in ipairs(v) do p[#p+1]=enc(val) end
                return "["..table.concat(p,",").."]"
            else
                local p={}
                for k,val in pairs(v) do p[#p+1]='"'..tostring(k)..'":'..enc(val) end
                return "{"..table.concat(p,",").."}"
            end
        end
        return "null"
    end
    return enc(t)
end

local function jsonDecode(s)
    local pos=1
    local function skip() while pos<=#s and s:sub(pos,pos):match("%s") do pos=pos+1 end end
    local function peek() skip(); return s:sub(pos,pos) end
    local function expect(c) skip(); pos=pos+1 end
    local parseVal
    local function parseStr()
        expect('"'); local r=""
        while pos<=#s do
            local c=s:sub(pos,pos); pos=pos+1
            if c=='"' then return r
            elseif c=="\\" then r=r..s:sub(pos,pos); pos=pos+1
            else r=r..c end
        end; return r
    end
    local function parseArr()
        expect('['); local t={}; skip()
        if peek()==']' then pos=pos+1; return t end
        repeat t[#t+1]=parseVal(); skip()
            if peek()==',' then pos=pos+1 end
        until peek()==']'
        pos=pos+1; return t
    end
    local function parseObj()
        expect('{'); local t={}; skip()
        if peek()=='}' then pos=pos+1; return t end
        repeat
            skip(); local k=parseStr(); skip(); expect(':')
            t[k]=parseVal(); skip()
            if peek()==',' then pos=pos+1 end
        until peek()=='}'
        pos=pos+1; return t
    end
    parseVal=function()
        skip(); local c=peek()
        if c=='"' then return parseStr()
        elseif c=='{' then return parseObj()
        elseif c=='[' then return parseArr()
        elseif c=='t' then pos=pos+4; return true
        elseif c=='f' then pos=pos+5; return false
        elseif c=='n' then pos=pos+4; return nil
        else
            local n=s:match("^-?%d+%.?%d*[eE]?[+-]?%d*",pos)
            pos=pos+(#n); return tonumber(n)
        end
    end
    local ok,r=pcall(parseVal); return ok and r or {}
end

-- Load saved config at startup (fully guarded)
local SavedConfig = {}
do
    local raw = safeRead(SAVE_FILE)
    if raw then
        local ok, decoded = pcall(jsonDecode, raw)
        if ok and type(decoded) == "table" then
            SavedConfig = decoded
        else
            -- File exists but is corrupt — back it up and start fresh
            if HAS_IO and type(writefile) == "function" then
                pcall(writefile, SAVE_FILE .. ".bak", raw)
            end
            SavedConfig = {}
        end
    end
end

-- Registry of saveable controls: Flag -> { ctype, obj }
local SaveRegistry = {}
local AutoSaveEnabled = SavedConfig.__autosave == nil and false or SavedConfig.__autosave

local function doSaveAll()
    if not HAS_IO then return end
    local out={ __autosave=AutoSaveEnabled, __theme=SavedConfig.__theme or "white" }
    for key,entry in pairs(SaveRegistry) do
        local ct = entry.ctype
        if ct=="toggle" or ct=="slider" then
            out[key] = NullLib.Flags[key]
        elseif ct=="dropdown" then
            local sel={}
            if type(NullLib.Flags[key])=="table" then
                for v in pairs(NullLib.Flags[key]) do sel[#sel+1]=v end
            end
            out[key] = sel
        elseif ct=="keybind" then
            local kv = NullLib.Flags[key]
            out[key] = kv and kv.Name or "Unknown"
        end
    end
    -- Guard encode step
    local ok, encoded = pcall(jsonEncode, out)
    if not ok or type(encoded) ~= "string" then return end
    -- Attempt write, retry once on failure (some executors are flaky)
    local wrote = safeWrite(SAVE_FILE, encoded)
    if not wrote then
        task.wait(0.5)
        safeWrite(SAVE_FILE, encoded)
    end
end

local function trySave()
    if AutoSaveEnabled then
        task.spawn(function() pcall(doSaveAll) end)
    end
end

